# Variables de entorno necesarias para el proyecto
# Copia este archivo como .env y rellena con tus valores reales

# ============================================
# BASE DE DATOS (PostgreSQL)
# En Railway: se genera automáticamente al añadir un servicio PostgreSQL
# ============================================
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db"

# ============================================
# WOMPI (Pagos colombianos: PSE, Nequi, Tarjeta)
# Obtén tus keys en: https://comercios.wompi.co
# ============================================
WOMPI_PUBLIC_KEY="tu_clave_publica_de_wompi_aqui"
WOMPI_PRIVATE_KEY="tu_clave_privada_de_wompi_aqui"

# ============================================
# URL DE LA APP
# En local: http://localhost:3000
# En Railway: tu dominio generado (ej: https://tu-app.up.railway.app)
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# SEGURIDAD
# Genera un string aleatorio largo para firmar tokens/sesiones
# ============================================
NEXTAUTH_SECRET="genera-un-string-aleatorio-aqui-muy-largo-y-seguro"
NEXTAUTH_URL="http://localhost:3000"
